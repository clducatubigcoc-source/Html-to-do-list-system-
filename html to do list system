    // ✅ FINAL VALIDATION + AUTO CAPITALIZATION
    static String getValidWord() {
        while (true) {
            String input = sc.nextLine().trim().toLowerCase();

            if (input.isEmpty()) {
                System.out.print("Invalid input! Try again: ");
                continue;
            }

            if (!input.matches("[a-zA-Z ]+")) {
                System.out.print("Invalid input! Try again: ");
                continue;
            }

            if (input.length() < 3) {
                System.out.print("Invalid input! Try again: ");
                continue;
            }

            String[] words = input.split("\\s+");
            boolean validWordFound = false;

            for (String word : words) {

                if (word.length() < 3) continue;

                if (word.matches("(.)\\1{2,}")) continue;

                if (word.length() >= 10) continue;

                if (!word.matches(".*[aeiou].*")) continue;

                validWordFound = true;
            }

            if (!validWordFound) {
                System.out.print("Invalid input! Try again: ");
                continue;
            }

            String[] bannedNames = {
                "john", "maria", "jose", "anna", "mark",
                "paul", "peter", "james", "kevin", "alex",
                "daniel", "joshua", "michelle", "sarah", "kent"
            };

            for (String name : bannedNames) {
                if (input.equals(name)) {
                    System.out.print("Invalid input! Try again: ");
                    continue;
                }
            }

            // ✅ AUTO CAPITALIZATION
            StringBuilder formatted = new StringBuilder();
            for (String word : words) {
                formatted.append(Character.toUpperCase(word.charAt(0)))
                         .append(word.substring(1))
                         .append(" ");
            }

            return formatted.toString().trim();
        }
    }

